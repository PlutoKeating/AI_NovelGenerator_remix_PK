# Backend API base URL
# This is the URL the frontend browser uses to call the backend
# In Docker: use the exposed host port (e.g., http://localhost:8000/api)
# In dev:    use the backend dev server (e.g., http://localhost:8000/api)
VITE_API_BASE_URL=http://localhost:8989/api

# Optional: Set to 'true' to enable debug logging
VITE_DEBUG=false
