# Server configuration
# APP_HOST: Bind address inside container (usually 0.0.0.0)
APP_HOST=0.0.0.0
# APP_PORT: Port the FastAPI server listens on INSIDE the container
APP_PORT=8000

# Logging
LOG_LEVEL=INFO

# CORS - comma-separated list of allowed origins
# Use "*" to allow all origins (dev only)
CORS_ORIGINS=*

# Data directory for novels and vector stores
DATA_DIR=./data

# WebDAV default config (optional)
# WEBDAV_URL=
# WEBDAV_USERNAME=
# WEBDAV_PASSWORD=
