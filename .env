# =============================================================================
# Docker Compose Port Configuration
# =============================================================================
# These variables control the port mappings between your host machine and
# the Docker containers. You can change them freely to avoid port conflicts.
#
# Format reminder: "HOST_PORT:CONTAINER_PORT"
# - HOST_PORT:      What port you access on your local machine/browser
# - CONTAINER_PORT: What port the application listens on INSIDE the container
# =============================================================================

# Backend Ports
# BACKEND_HOST_PORT:      Port on your host machine to access the backend API
# BACKEND_CONTAINER_PORT: Port the FastAPI server listens on inside the container
#                         (must match APP_PORT in backend/.env)
BACKEND_HOST_PORT=8989
BACKEND_CONTAINER_PORT=8000

# Frontend Ports
# FRONTEND_HOST_PORT:      Port on your host machine to access the web UI
# FRONTEND_CONTAINER_PORT: Port nginx listens on inside the container
#                          (must match the 'listen' directive in frontend/nginx.conf)
FRONTEND_HOST_PORT=5768
FRONTEND_CONTAINER_PORT=80

# =============================================================================
# Quick Reference for Common Port Changes
# =============================================================================
# If port 80 is already in use (e.g., by another web server):
#   FRONTEND_HOST_PORT=8080
#
# If port 8000 is already in use (e.g., by another API server):
#   BACKEND_HOST_PORT=8898
#
# If you want to run multiple instances:
#   Instance 1: BACKEND_HOST_PORT=8000, FRONTEND_HOST_PORT=80
#   Instance 2: BACKEND_HOST_PORT=8001, FRONTEND_HOST_PORT=81
# =============================================================================
